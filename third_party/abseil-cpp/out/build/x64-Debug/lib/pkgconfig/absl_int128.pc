prefix=F:/lambdatest/src/third_party/abseil-cpp/out/install/x64-Debug
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include

Name: absl_int128
Description: Abseil int128 library
URL: https://abseil.io/
Version: head
Requires: absl_config = head, absl_core_headers = head, absl_bits = head
Libs: -L${libdir}  -labsl_int128
Cflags: -I${includedir} /W3 /DNOMINMAX /DWIN32_LEAN_AND_MEAN /D_CRT_SECURE_NO_WARNINGS /D_SCL_SECURE_NO_WARNINGS /D_ENABLE_EXTENDED_ALIGNED_STORAGE /bigobj /wd4005 /wd4068 /wd4180 /wd4244 /wd4267 /wd4503 /wd4800
